{
  "name": "kle-ng",
  "version": "0.39.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:docs": "vitepress dev docs",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:docs": "vitepress build docs",
    "preview": "vite preview",
    "test:unit": "vitest run --reporter=github-actions",
    "test:unit:watch": "vitest watch",
    "test:e2e": "playwright test",
    "test:e2e:headless": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project chromium",
    "test:e2e:update": "playwright test --update-snapshots=all",
    "test:e2e:update-chromium": "playwright test --project chromium --update-snapshots=all",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --log-level silent --write src/ e2e/ docs/"
  },
  "dependencies": {
    "@adamws/kle-serial": "github:adamws/kle-serial2#v0.19.0",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@jscad/modeling": "^2.13.0",
    "@jscad/stl-serializer": "^2.1.23",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "decimal.js": "^10.6.0",
    "ergogen": "^4.2.1",
    "fuse.js": "^7.3.0",
    "js-yaml": "^4.1.1",
    "json5": "^2.2.3",
    "lz-string": "^1.5.0",
    "makerjs": "^0.19.2",
    "medium-zoom": "^1.1.0",
    "pinia": "^3.0.4",
    "polygon-clipping": "^0.15.7",
    "three": "^0.183.2",
    "vue": "^3.5.27"
  },
  "overrides": {
    "ergogen": {
      "kle-serial": "github:adamws/kle-serial2#v0.19.0"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/file-saver": "^2.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.1.0",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/eslint-plugin": "^1.6.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "dxf-json": "^0.11.0",
    "eslint": "^9.39.2",
    "eslint-plugin-playwright": "^2.5.1",
    "eslint-plugin-vue": "~10.7.0",
    "jiti": "^2.6.1",
    "jsdom": "^27.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.1",
    "sass": "^1.97.3",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vite-svg-loader": "^5.1.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4"
  }
}
